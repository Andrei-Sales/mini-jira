DB_HOST=db.<your-project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
# Optional override if you prefer a full JDBC string:
# DB_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
# If direct host fails with UnknownHostException in an IPv4-only environment,
# use Supabase Session pooler (Dashboard -> Connect) and set:
# DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# DB_USERNAME=postgres.<your-project-ref>
DB_USERNAME=postgres
DB_PASSWORD=<your-supabase-db-password>
JWT_SECRET=<at-least-32-characters-secret>
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_SEED_ENABLED=true
